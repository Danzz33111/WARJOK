<!-- LIGHTBOX -->
<div class="lightbox" id="lightbox">
  <div class="lightbox-controls">
    <span class="minimize-btn" onclick="toggleMinimize()">−</span>
    <span class="close-btn" onclick="closeLightbox()">×</span>
  </div>
  
  <div class="media-container" id="media-container"></div>
  
  <div class="lightbox-nav">
    <button onclick="goToPrev()">❮</button>
    <button onclick="goToNext()">❯</button>
    <button id="auto-slide-btn" onclick="toggleAutoSlide()">Auto Slide OFF</button>
  </div>
</div>

<!-- MUSIK -->
<audio id="bgMusic" loop preload="auto">
  <source src="Hindia - everything u are.mp3" type="audio/mpeg">
</audio>

<script>
// Throttle helper
function throttle(fn, delay = 180) {
  let last = 0;
  return function(...args) {
    const now = Date.now();
    if (now - last >= delay) {
      fn(...args);
      last = now;
    }
  };
}

// Variabel global
let currentIndex = 0;
let slideInterval = null;
let isMinimized = false;
let autoSlideEnabled = false;

const photos = document.querySelectorAll('.photo-card');
const lightbox = document.getElementById('lightbox');
const mediaContainer = document.getElementById('media-container');
const autoBtn = document.getElementById('auto-slide-btn');

// Canvas Stars (dioptimasi)
const canvas = document.getElementById('stars-canvas');
const ctx = canvas.getContext('2d', { alpha: true });
let w = canvas.width = window.innerWidth;
let h = canvas.height = window.innerHeight;
let layers = [];
let meteors = [];
let time = 0;

function initLayers() {
  const isMobile = w < 768;
  layers = [
    {count: isMobile ? 90 : 180, speed: 0.018, size: 1.2},
    {count: isMobile ? 70 : 140, speed: 0.045, size: 1.8},
    {count: isMobile ? 45 : 90,  speed: 0.09,  size: 2.4}
  ];
  layers.forEach(layer => {
    layer.stars = [];
    for(let i = 0; i < layer.count; i++){
      layer.stars.push({
        x: Math.random() * w,
        y: Math.random() * h,
        baseOpacity: Math.random() * 0.6 + 0.4,
        twinklePhase: Math.random() * Math.PI * 2
      });
    }
  });
}

function createMeteor() {
  if (meteors.length > 7) return;
  const isBig = Math.random() < 0.13;
  const speed = isBig ? Math.random() * 14 + 11 : Math.random() * 9 + 5;
  const angle = Math.random() * Math.PI / 5 + Math.PI / 10;
  meteors.push({
    x: Math.random() * w * 0.6 + w * 0.2,
    y: -100,
    speedX: -speed * Math.cos(angle),
    speedY: speed * Math.sin(angle),
    width: isBig ? 4.5 : 3,
    opacity: 1,
    isBig
  });
}

function drawScene() {
  ctx.clearRect(0, 0, w, h);
  time += 0.75;

  // Stars
  layers.forEach(layer => {
    ctx.shadowBlur = 10;
    ctx.shadowColor = '#4cc9f0';
    layer.stars.forEach(star => {
      const opacity = star.baseOpacity + Math.sin(time * 0.019 + star.twinklePhase) * 0.28;
      ctx.beginPath();
      ctx.arc(star.x, star.y, layer.size * (0.7 + opacity * 0.6), 0, Math.PI * 2);
      ctx.fillStyle = `rgba(200, 240, 255, ${opacity})`;
      ctx.fill();

      star.y += layer.speed;
      if (star.y > h) star.y = -10;
    });
  });

  // Meteors
  ctx.shadowBlur = 28;
  for (let i = meteors.length - 1; i >= 0; i--) {
    const m = meteors[i];
    const alpha = m.opacity;

    // tail
    ctx.strokeStyle = `rgba(180,230,255,${alpha*0.75})`;
    ctx.lineWidth = m.width;
    ctx.beginPath();
    ctx.moveTo(m.x, m.y);
    ctx.lineTo(m.x - m.speedX*1.6, m.y - m.speedY*1.6);
    ctx.stroke();

    // head
    ctx.fillStyle = `rgba(255,255,255,${alpha})`;
    ctx.shadowColor = '#4cc9f0';
    ctx.beginPath();
    ctx.arc(m.x, m.y, m.width + 1.5, 0, Math.PI * 2);
    ctx.fill();

    m.x += m.speedX;
    m.y += m.speedY;
    m.opacity -= 0.016;

    if (m.opacity <= 0 || m.y > h + 180) {
      if (m.isBig && Math.random() < 0.45) {
        createSimpleBurst(m.x, m.y);
      }
      meteors.splice(i, 1);
    }
  }
  requestAnimationFrame(drawScene);
}

function createSimpleBurst(x, y) {
  for (let i = 0; i < 12; i++) {
    const burst = document.createElement("div");
    burst.className = "heart-explosion";
    burst.style.position = "fixed";
    burst.style.left = x + "px";
    burst.style.top = y + "px";
    burst.style.fontSize = (Math.random() * 1.6 + 1.4) + "rem";
    burst.innerHTML = "★";
    burst.style.setProperty('--dx', (Math.random()-0.5)*260 + 'px');
    burst.style.setProperty('--dy', (Math.random()-0.5)*260 + 'px');
    burst.style.setProperty('--rot', Math.random()*600 + 'deg');
    document.body.appendChild(burst);
    setTimeout(() => burst.remove(), 1400);
  }
}

const throttledResize = throttle(() => {
  w = canvas.width = window.innerWidth;
  h = canvas.height = window.innerHeight;
  initLayers();
}, 200);

window.addEventListener('resize', throttledResize);

initLayers();
setInterval(createMeteor, 750);
drawScene();

// Particles (dioptimasi)
function createParticle(){
  const container = document.getElementById("particles");
  if (container.children.length > 28) return;

  const p = document.createElement("div");
  p.className = "particle";
  p.innerHTML = "★";
  p.style.fontSize = (Math.random() * 1.6 + 1.3) + "rem";
  p.style.left = Math.random() * 100 + "vw";
  p.style.animationDuration = (Math.random() * 11 + 16) + "s";
  container.appendChild(p);
  setTimeout(() => p.remove(), 32000);
}
setInterval(createParticle, window.innerWidth < 768 ? 320 : 220);

// Heart Explosion
function createHeartExplosion(e, card) {
  const x = e.clientX;
  const y = e.clientY;
  for(let i = 0; i < 22; i++){
    const star = document.createElement("div");
    star.className = "heart-explosion";
    star.style.position = "fixed";
    star.style.left = x + "px";
    star.style.top = y + "px";
    star.style.fontSize = (Math.random() * 2 + 1.4) + "rem";
    star.innerHTML = "★";
    const dx = (Math.random() - 0.5) * 340;
    const dy = (Math.random() - 0.6) * 340;
    star.style.setProperty('--dx', dx + 'px');
    star.style.setProperty('--dy', dy + 'px');
    star.style.setProperty('--rot', Math.random() * 900 - 450 + 'deg');
    document.body.appendChild(star);
    setTimeout(() => star.remove(), 1550);
  }
}

// Overlay & Music
const overlay = document.getElementById('overlay');
const music = document.getElementById("bgMusic");

function playMusic(){
  music.volume = 0;
  music.play().catch(() => {});
  let vol = 0;
  const fade = setInterval(() => {
    vol += 0.018;
    if (vol >= 0.42) {
      music.volume = 0.42;
      clearInterval(fade);
    } else music.volume = vol;
  }, 90);
}

overlay.addEventListener('click', () => {
  overlay.classList.add('fade-out');
  setTimeout(() => overlay.style.display = 'none', 1000);
  playMusic();
});

// Lightbox Functions (tetap sama, hanya sedikit lebih efisien)
function showSlide(){
  const currentCard = photos[currentIndex];
  const media = currentCard.querySelector('img, video');
  const captionText = currentCard.querySelector('.caption').textContent;

  mediaContainer.innerHTML = '';

  if(media.tagName === 'VIDEO'){
    const video = document.createElement('video');
    video.src = media.src;
    video.controls = true;
    video.autoplay = true;
    video.loop = false;
    video.muted = false;
    video.playsInline = true;
    mediaContainer.appendChild(video);
    video.play().catch(() => {});
    video.addEventListener('ended', () => { if(autoSlideEnabled) goToNext(); });
  } else {
    const img = document.createElement('img');
    img.src = media.src;
    mediaContainer.appendChild(img);
  }

  const captionEl = document.createElement('div');
  captionEl.className = 'lightbox-caption';
  captionEl.textContent = captionText;
  mediaContainer.appendChild(captionEl);
}

function resetTimer(){
  clearInterval(slideInterval);
  if(autoSlideEnabled) slideInterval = setInterval(goToNext, 4500);
}

function goToNext(){
  currentIndex = (currentIndex + 1) % photos.length;
  showSlide();
  if(autoSlideEnabled) resetTimer();
}

function goToPrev(){
  currentIndex = (currentIndex - 1 + photos.length) % photos.length;
  showSlide();
  if(autoSlideEnabled) resetTimer();
}

function toggleAutoSlide(){
  autoSlideEnabled = !autoSlideEnabled;
  if(autoSlideEnabled){
    autoBtn.textContent = "Auto Slide ON";
    autoBtn.classList.add('active');
    resetTimer();
  } else {
    autoBtn.textContent = "Auto Slide OFF";
    autoBtn.classList.remove('active');
    clearInterval(slideInterval);
  }
}

function toggleMinimize(){
  isMinimized = !isMinimized;
  lightbox.classList.toggle('minimized');
  if (!isMinimized) resetTimer();
}

function closeLightbox(){
  lightbox.classList.remove('active');
  lightbox.classList.remove('minimized');
  isMinimized = false;
  clearInterval(slideInterval);
  const video = mediaContainer.querySelector('video');
  if(video) video.pause();
}

// Event klik gallery
photos.forEach((card, i) => {
  card.addEventListener('click', (e) => {
    createHeartExplosion(e, card);
    currentIndex = i;
    lightbox.classList.add('active');
    isMinimized = false;
    showSlide();
  });
});
</script>

</body>
