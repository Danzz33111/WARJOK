<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Our Memory</title>

<style>
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}

body{
  min-height:100vh;
  font-family:'Segoe UI',system-ui,sans-serif;
  background:#0a001f;
  color:#e0f7ff;
  overflow-x:hidden;
  position:relative;
}

#stars-canvas{
  position:fixed;
  inset:0;
  z-index:0;
  pointer-events:none;
}

/* Overlay */
#overlay{
  position:fixed;
  inset:0;
  background:rgba(10,0,31,0.95); /* sedikit lebih ringan */
  display:flex;
  justify-content:center;
  align-items:center;
  flex-direction:column;
  z-index:99999;
  cursor:pointer;
  text-align:center;
  padding:20px;
  transition:opacity 1s ease;
}
#overlay.fade-out{opacity:0; pointer-events:none;}

/* Judul */
h1{
  text-align:center;
  padding:80px 20px 60px;
  font-size:3.5rem;
  color:#4cc9f0;
  text-shadow:0 0 30px #00b4d8, 0 0 60px #4cc9f0;
  position:relative;
  z-index:2;
  animation:pulse-glow 4s ease-in-out infinite alternate;
}
@keyframes pulse-glow{
  from{text-shadow:0 0 30px #00b4d8, 0 0 60px #4cc9f0;}
  to{text-shadow:0 0 40px #00b4d8, 0 0 80px #90e0ff;}
}

/* Gallery */
.gallery{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
  gap:35px;
  padding:0 6% 100px;
  max-width:1500px;
  margin:auto;
  position:relative;
  z-index:2;
}

.photo-card{
  position:relative;
  border-radius:24px;
  overflow:hidden;
  cursor:pointer;
  transition:transform 0.8s cubic-bezier(0.23, 1, 0.32, 1), box-shadow 0.8s ease;
  background:rgba(255,255,255,.06);
  box-shadow:0 10px 30px rgba(0,0,0,0.4);
  will-change: transform;
}

.photo-card:hover{
  transform:translateY(-15px) scale(1.06);
  box-shadow:0 30px 70px rgba(0, 180, 216, .6);
}

.photo-card img,
.photo-card video{
  width:100%;
  height:360px;
  object-fit:cover;
  display:block;
  transition:transform 1s cubic-bezier(0.23, 1, 0.32, 1);
  will-change: transform;
}

.photo-card:hover img,
.photo-card:hover video{
  transform:scale(1.12);
}

.caption{
  position:absolute;
  bottom:0;
  width:100%;
  padding:25px 15px;
  background:linear-gradient(to top,rgba(0,0,0,.9),transparent);
  text-align:center;
  font-size:1.2rem;
  color:#e0f7ff;
  text-shadow:0 0 15px #000;
}

/* Lightbox */
.lightbox{
  opacity:0;
  visibility:hidden;
  position:fixed;
  inset:0;
  background:rgba(0,0,0,.97);
  display:flex;
  flex-direction:column;
  justify-content:center;
  align-items:center;
  z-index:9999;
  transition:opacity 0.6s ease;
  padding:30px 20px;
}

.lightbox.active{
  opacity:1;
  visibility:visible;
}

.media-container {
  position: relative;
  max-width: 95vw;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 15px;
}

.lightbox img,
.lightbox video{
  max-width: 100%;
  max-height: 78vh;
  width: auto;
  height: auto;
  border-radius: 24px;
  box-shadow:0 0 80px rgba(0, 180, 216, .8);
  object-fit: contain;
}

.lightbox-caption {
  font-size: 1.35rem;
  color: #4cc9f0;
  text-align: center;
  text-shadow: 0 0 15px #000;
  padding: 0 20px;
  max-width: 90%;
}

.lightbox-controls{
  position:absolute;
  top:25px;
  right:35px;
  display:flex;
  gap:20px;
  z-index:12000;
}

.minimize-btn, .close-btn{
  font-size:48px;
  color:#4cc9f0;
  text-shadow:0 0 20px #00b4d8;
  cursor:pointer;
  transition:transform 0.3s ease;
}

.minimize-btn:hover, .close-btn:hover{
  transform:scale(1.25);
  color:#90e0ff;
}

.lightbox-nav{
  display:flex;
  justify-content:center;
  align-items:center;
  gap:15px;
  margin-top: 15px;
  z-index:12000;
}

.lightbox-nav button{
  background:rgba(0,0,0,0.75);
  border: 2px solid rgba(76, 201, 240, 0.8);
  color:#4cc9f0;
  font-size:52px;
  width:75px;
  height:75px;
  border-radius:50%;
  cursor:pointer;
  box-shadow:0 0 30px rgba(0, 180, 216, 0.9), 0 10px 40px rgba(0,0,0,0.7);
  transition: all 0.3s ease;
}

.lightbox-nav button:hover{
  background:rgba(0, 180, 216, 0.5);
  color:#ffffff;
  border-color:#90e0ff;
  transform:scale(1.12);
}

#auto-slide-btn {
  background:rgba(0,0,0,0.75);
  border: 2px solid rgba(76, 201, 240, 0.8);
  color:#4cc9f0;
  font-size:15px;
  padding:12px 28px;
  border-radius:30px;
  cursor:pointer;
  box-shadow:0 0 25px rgba(0, 180, 216, 0.7);
  transition:0.3s ease;
  white-space:nowrap;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
}

#auto-slide-btn:hover {
  background:rgba(0, 180, 216, 0.5);
  color:#fff;
  border-color:#90e0ff;
  transform:scale(1.05);
}

#auto-slide-btn.active {
  background:rgba(0, 180, 216, 0.8);
  color:#fff;
}

/* Particles */
.particles{
  position:fixed;
  inset:0;
  pointer-events:none;
  overflow:hidden;
  z-index:1;
}

.particle{
  position:absolute;
  color:#4cc9f0;
  text-shadow:0 0 15px rgba(76, 201, 240, 0.95);
  animation:fall linear forwards, sway 7s ease-in-out infinite alternate;
  opacity:0;
  will-change: transform, opacity;
}

@keyframes fall{from{transform:translateY(-150vh) rotate(0deg);} to{transform:translateY(150vh) rotate(1080deg);}}
@keyframes sway{from{transform:translateX(-40px);} to{transform:translateX(40px);}}
</style>
</head>

